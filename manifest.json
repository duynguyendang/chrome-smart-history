{
  "manifest_version": 3,
  "name": "Smart History — Semantic Memory",
  "version": "1.0.0",
  "description": "Turn your browser history into a semantic knowledge base. Embed pages on-device with EmbeddingGemma and search by meaning. No cloud, no Cloudflare.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "history",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Smart History"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/extract.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
